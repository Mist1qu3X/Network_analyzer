<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Analyzer Pro v1.2" Height="750" Width="950"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#DCDDE1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEDF0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="280"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="СЕТЕВОЙ МОНИТОРИНГ" FontSize="24" FontWeight="Black" Foreground="#2C3E50"/>
            <Rectangle Height="4" Fill="#3498DB" HorizontalAlignment="Left" Width="60" Margin="2,5,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="12" Margin="0,0,10,0" BorderBrush="#E0E4E8" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Адаптеры" Margin="15,15,15,5" FontWeight="Bold" Foreground="#7F8C8D"/>
                    <ListBox x:Name="listInterfaces" Margin="10" BorderThickness="0" DisplayMemberPath="Name" SelectionChanged="ListInterfaces_SelectionChanged"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="10,0,0,0" BorderBrush="#E0E4E8" BorderThickness="1">
                <StackPanel Margin="20">
                    <TextBlock x:Name="txtInterfaceName" FontSize="16" FontWeight="Bold" Text="Выберите интерфейс" Margin="0,0,0,10" Foreground="#2C3E50"/>
                    <UniformGrid Columns="2">
                        <StackPanel Margin="0,5"><TextBlock Text="IP Адрес" FontSize="11" Foreground="#95A5A6"/><TextBlock x:Name="txtIpAddress" FontWeight="Medium"/></StackPanel>
                        <StackPanel Margin="0,5"><TextBlock Text="Статус" FontSize="11" Foreground="#95A5A6"/><TextBlock x:Name="txtStatus" FontWeight="Medium"/></StackPanel>
                        <StackPanel Margin="0,5"><TextBlock Text="Лимит канала" FontSize="11" Foreground="#95A5A6"/><TextBlock x:Name="txtSpeed" FontWeight="Medium"/></StackPanel>
                        <StackPanel Margin="0,5"><TextBlock Text="MAC" FontSize="11" Foreground="#95A5A6"/><TextBlock x:Name="txtMacAddress" FontWeight="Medium"/></StackPanel>
                        <StackPanel Margin="0,10,0,0"><TextBlock Text="Загрузка (↓)" FontSize="11" Foreground="#2ECC71"/><TextBlock x:Name="txtDownload" FontWeight="Bold" FontSize="14" Text="0.0 KB/s"/></StackPanel>
                        <StackPanel Margin="0,10,0,0"><TextBlock Text="Отдача (↑)" FontSize="11" Foreground="#E74C3C"/><TextBlock x:Name="txtUpload" FontWeight="Bold" FontSize="14" Text="0.0 KB/s"/></StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20" BorderBrush="#E0E4E8" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="txtUrl" Height="40" VerticalContentAlignment="Center" Padding="15,0" FontSize="14" BorderBrush="#DCDDE1"/>
                    <Button Grid.Column="1" Content="АНАЛИЗ URL" Click="BtnAnalyze_Click" Width="130" Margin="15,0,0,0" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </Grid>
                <DockPanel>
                    <UniformGrid Columns="3" Width="400" HorizontalAlignment="Left" Height="35">
                        <Button Content="Ping" Click="BtnPing_Click" Margin="0,0,5,0" Style="{StaticResource ActionButtonStyle}"/>
                        <Button Content="DNS Lookup" Click="BtnDns_Click" Margin="5,0,5,0" Style="{StaticResource ActionButtonStyle}"/>
                        <Button Content="Тип IP" Click="BtnAddressType_Click" Margin="5,0,0,0" Style="{StaticResource ActionButtonStyle}"/>
                    </UniformGrid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ComboBox x:Name="cmbHistory" Width="180" Margin="0,0,10,0" DisplayMemberPath="Url" SelectionChanged="CmbHistory_SelectionChanged"/>
                        <Button Content="Очистить" Click="BtnClearHistory_Click" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="12" Padding="15">
            <TextBox x:Name="txtResults" Background="Transparent" Foreground="#00FF00" BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"/>
        </Border>
    </Grid>
</Window>